# Security & caching headers for Journey Embraced Counseling
# Netlify reads this file automatically from the site root — no config change needed on your end.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self "https://js.stripe.com")
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://static.wixstatic.com https://js.stripe.com; frame-src https://js.stripe.com https://buy.stripe.com https://donate.stripe.com; connect-src 'self' https://api.stripe.com; form-action 'self' https://donate.stripe.com; base-uri 'self'; object-src 'none'; frame-ancestors 'none'

# Long-cache immutable static assets (filenames don't change on edit, so keep this moderate rather than 1-year)
/images/*
  Cache-Control: public, max-age=604800

/css/*
  Cache-Control: public, max-age=86400, must-revalidate

/js/*
  Cache-Control: public, max-age=86400, must-revalidate
